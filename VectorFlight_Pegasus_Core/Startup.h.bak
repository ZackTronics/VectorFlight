    timer4=new QTimer(this);    //Update Stored Settings
    connect(timer4, SIGNAL(timeout()), this, SLOT(monitorRetainDataForChangesToSave()));
    connect(timer4, SIGNAL(timeout()), this, SLOT(timer2_setInterval()));       //iControllerPacketInterval  will be applied to timer2, at least once every second.
