        msgBox.setStandardButtons(QMessageBox::Ok);
        int msgboxResult = msgBox.exec();
        UNUSED(msgboxResult);
        QString fileName = QFileDialog::getOpenFileName(this,
            tr("Open Settings"), "./", tr("Settings Files (*.stz)"));
        if (fileName != ""){
                int eCode = readRetainDataFromFile(fileName);
                UNUSED(eCode);
                writeRetainDataToFile(fileName);
                HandshakeStep = 0;
            }else{
            QMessageBox msgBox;
            msgBox.setText("No parameter was selected.  Communication is disabled until one is loaded.\n\n");
            msgBox.setStandardButtons(QMessageBox::Ok);
        }
//END_SWAP_DESK
