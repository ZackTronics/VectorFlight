ui->pushButton_2  ->setText("Lateral");       ui->pushButton_2  ->setEnabled(TRUE);
ui->pushButton_3  ->setText("Yaw");           ui->pushButton_3  ->setEnabled(TRUE);
ui->pushButton_4  ->setText("View");          ui->pushButton_4  ->setEnabled(TRUE);
*/


void MainWindow::populateMenu(){
    cleanupMenuButtons();
    if (menuNum == 1)    {
        ui->pushButton_1  ->setText("Autopilot");       ui->pushButton_1  ->setEnabled(TRUE);
        ui->pushButton_2  ->setText("Controls");        ui->pushButton_2  ->setEnabled(TRUE);
        ui->pushButton_3  ->setText("DBG TEST");         ui->pushButton_3  ->setEnabled(TRUE);
        }
    if (menuNum == 2)    {
        ui->pushButton_1  ->setText("Manual");     ui->pushButton_1  ->setEnabled(TRUE);
        ui->pushButton_2  ->setText("Home");       ui->pushButton_2  ->setEnabled(TRUE);
        ui->pushButton_3  ->setText("Land");       ui->pushButton_3  ->setEnabled(TRUE);
        ui->pushButton_4  ->setText("Hold");       ui->pushButton_4  ->setEnabled(TRUE);
        ui->pushButton_5  ->setText("Up");         ui->pushButton_5  ->setEnabled(TRUE);
        ui->pushButton_6  ->setText("Kill");       ui->pushButton_6  ->setEnabled(TRUE);
        ui->pushButton_7  ->setText("Exit");       ui->pushButton_7  ->setEnabled(TRUE);
        }
    if (menuNum == 3)    {
        ui->pushButton_1  ->setText("Throttle");      ui->pushButton_1  ->setEnabled(TRUE);
        ui->pushButton_2  ->setText("Lateral");       ui->pushButton_2  ->setEnabled(TRUE);
        ui->pushButton_3  ->setText("Yaw");           ui->pushButton_3  ->setEnabled(TRUE);
        ui->pushButton_4  ->setText("View");          ui->pushButton_4  ->setEnabled(TRUE);
        ui->pushButton_5  ->setText("");              ui->pushButton_5  ->setEnabled(TRUE);
        ui->pushButton_6  ->setText("");              ui->pushButton_6  ->setEnabled(TRUE);
        ui->pushButton_7  ->setText("Exit");          ui->pushButton_7  ->setEnabled(TRUE);
        }
    if (menuNum == 200)    {
        ui->pushButton_1  ->setText("Autopilot");
        ui->pushButton_1  ->setEnabled(TRUE);
        ui->pushButton_2  ->setText("Controls");
        ui->pushButton_2  ->setEnabled(TRUE);
        }
     if (menuNum == 300)    {
        ui->pushButton_7  ->setText("Exit");
        ui->pushButton_7  ->setEnabled(TRUE);
        }
     if (menuNum == 400)    {
        ui->pushButton_1  ->setEnabled(TRUE);
        ui->pushButton_2  ->setEnabled(TRUE);
        }
     if (menuNum == 500)    {
        }

    }
void MainWindow::cleanupMenuButtons(){
    ui->pushButton_1->setEnabled(FALSE);
    ui->pushButton_2->setEnabled(FALSE);
    ui->pushButton_3->setEnabled(FALSE);
    ui->pushButton_4->setEnabled(FALSE);
    ui->pushButton_5->setEnabled(FALSE);
    ui->pushButton_6->setEnabled(FALSE);
    ui->pushButton_7->setEnabled(FALSE);
    ui->pushButton_1->setText("B1");
    ui->pushButton_2->setText("B2");
    ui->pushButton_3->setText("B3");
    ui->pushButton_4->setText("B4");
    ui->pushButton_5->setText("B5");
    ui->pushButton_6->setText("B6");
    ui->pushButton_7->setText("B7");
    }


//Go to Normal Mode
void MainWindow::on_action_Normal_Mode_triggered(){
    gProgMode = num_normalMode;
    menuNum = 1;
    populateMenu();
    }
//Mode 01 - Calibrate Mode
void MainWindow::on_actionCalibrate_Controller_triggered()  {
    gProgMode                           = num_calibrateMode;    //there is only one controller.  This is the program calibrate mode.
    Ctrl.calibMode                      = 1;                    //sets the particular controller object's function into calibrate mode
    calibrationRoutineShare.calibStep   = 0;                    //find zero position
    menuNum = 200;
    populateMenu();
    }
//Mode 02 - View Controller mode
void MainWindow::on_actionView_Controller_triggered(){
    gProgMode = num_viewControllerMode;
    menuNum = 300;
    populateMenu();
    }
void MainWindow::on_actionDBG_See_Rmote_Controller_triggered(){
    gProgMode = num_viewRmtCtrlMode;
    menuNum = 500;
    populateMenu();

    }
//Mode 04
void MainWindow::on_actionView_Comms_Log_2_triggered(){
    gProgMode = num_viewCommsLog;
    glbLogCanScroll[defCommsLog]  = 1;  //default is 0 to minimize CPU load
    menuNum = 400;
    populateMenu();
    //The text on these buttons is updated in realtime in Display-->Mode_04_viewCommsLog.h
    }
//Mode 05
void MainWindow::on_actionView_Events_Log_triggered(){
    gProgMode = num_viewEventLog;
    glbLogCanScroll[defEventLog]  = 1;  //default is 0 to minimize CPU load
    menuNum = 400;
    populateMenu();
    //These text on these buttons is updated in realtime in Display-->Mode_04_viewCommsLog.h
    }




//Enable Logging
void MainWindow::on_actionEnable_Advanced_Logging_triggered()
{
    savePolledVarsToDisk = 1;
}











#endif // MENUBUTTONROW_H
