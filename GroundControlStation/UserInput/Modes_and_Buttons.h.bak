void ExitMode_01() {
        Ctrl.calibMode                      = 0;
        calibrationRoutineShare.calibStep   = 0;
        gProgMode                           = num_normalMode;
    }

//Quit
void MainWindow::on_actionQuit_triggered(){
    QApplication::quit();
    }
//Mode 00 - Initial Mode
void MainWindow::on_enteringInitialMode(){
    on_action_Normal_Mode_triggered();
    }
void MainWindow::on_actionRe_Handshake_With_Chopper_triggered()
    {
    //qDebug() << "Re Handshake!";
    InformUserOfHandshakeSuccess =1;
    HandshakeStep =1;
    }


//**************************************************************
//          THESE FUNCTIONS DEFINE THE ACTIONS THAT OCCUR WHEN
//          THE BUTTONS ACCROSS THE BOTTOM OF THE SCREEN ARE CLICKED
//*************************************************************
void MainWindow::on_pushButton_1_clicked(){
         if (menuNum == 200)                     {CtrlCalibShare  = EmptyStruct_CtrlCalibShare;}   //This is an empty controller structure with value=0 used to zero the controller structure
    else if (menuNum == 400)                     {glbLogCanScroll[gProgMode - 1000] = !glbLogCanScroll[gProgMode - 1000];}
    else if (menuNum == 1  )                     {menuNum = 2; populateMenu();}
    else if (menuNum == 2  )                     {AutoPilot_Enabled = 0;pushSuperVarWrite("AutoPilot_Enabled"); releaseOutPacket(criticalPacket);}
    else if (menuNum == 3  )                     {if (UserInput_AutoClimb) UserInput_AutoClimb = 0; else UserInput_AutoClimb = 1;
                                                    if (connectionStatus>0)   {pushSuperVarWrite("UserInput_AutoClimb");
                                                    releaseOutPacket(criticalPacket);}}
    }
void MainWindow::on_pushButton_2_clicked(){
         if (menuNum == 400)                     {glbLogWriteToFile[gProgMode - 1000] = !glbLogWriteToFile[gProgMode - 1000];}
    else if (menuNum == 1  )                     {menuNum = 3; populateMenu();}
    else if (menuNum == 2  )                     {AutoPilot_Enabled = 1;pushSuperVarWrite("AutoPilot_Enabled"); releaseOutPacket(criticalPacket);}
    else if (menuNum == 3  )                     {if (UserInput_AutoLateral) UserInput_AutoLateral = 0; else UserInput_AutoLateral = 1;
                                                    if (connectionStatus>0)   {pushSuperVarWrite("UserInput_AutoLateral");
                                                    releaseOutPacket(criticalPacket);}}
    }
void MainWindow::on_pushButton_3_clicked(){
         if (menuNum == 2  )                     {AutoPilot_Enabled = 2;pushSuperVarWrite("AutoPilot_Enabled"); releaseOutPacket(criticalPacket);}
    else if (menuNum == 3  )                     {if (UserInput_AutoYaw) UserInput_AutoYaw = 0;  else UserInput_AutoYaw = 1;
                                                    if (connectionStatus>0)   {pushSuperVarWrite("UserInput_AutoYaw");
                                                    releaseOutPacket(criticalPacket);}}
    else if (menuNum ==1){

             PleaseXmitChanges();



             /*
             qDebug() << "KILLLL";
         //wipe the connection log if making a connection
             for (int x = 0; x < sentPacketLogLength; x++){  //loop through every element of sent packet log
//             sentPacketsLog[x]           = blankSentPacketLogEntry;
             }  */
         }

    }
void MainWindow::on_pushButton_4_clicked(){
         if (menuNum == 2  )                     {AutoPilot_Enabled = 3;pushSuperVarWrite("AutoPilot_Enabled"); releaseOutPacket(criticalPacket);}
    else if (menuNum == 3  )                     {if (UserInput_ControlAzimuthIsHeliRelative) UserInput_ControlAzimuthIsHeliRelative = 0; else UserInput_ControlAzimuthIsHeliRelative = 1;
                                                    if (connectionStatus>0)   {pushSuperVarWrite("UserInput_ControlAzimuthIsHeliRelative");
                                                    releaseOutPacket(criticalPacket);}}
    }
void MainWindow::on_pushButton_5_clicked(){
         if (menuNum == 2  )                     {AutoPilot_Enabled = 4;pushSuperVarWrite("AutoPilot_Enabled"); releaseOutPacket(criticalPacket);}
    else if (menuNum == 3  )                     {}
    }
void MainWindow::on_pushButton_6_clicked(){
         if (menuNum == 2  )                     {AutoPilot_Enabled = 5;pushSuperVarWrite("AutoPilot_Enabled"); releaseOutPacket(criticalPacket);}
    else if (menuNum == 3  )                     {}
    }
void MainWindow::on_pushButton_7_clicked(){
    if (menuNum == 200)                     {on_enteringInitialMode();}
    else if (menuNum == 500)                     {on_enteringInitialMode();}
    else if (menuNum == 2  )                     {menuNum = 1; populateMenu();}
    else if (menuNum == 3  )                     {menuNum = 1; populateMenu();}
    }



















